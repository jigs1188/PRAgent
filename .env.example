# ── LLM ──
LLM_PROVIDER=gemini
MODEL_NAME=gemini-2.5-flash

# ── API Keys (at minimum set GOOGLE_API_KEY) ──
GOOGLE_API_KEY=your_google_api_key_here
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GITHUB_TOKEN=                  # optional – raises GitHub API rate limit


# ── Embeddings ──
# gemini-embedding-001 (3072 dims) – universally available, matches the default Pinecone index.
# NOTE: text-embedding-004 is NOT available on the v1beta API endpoint; do not use it.
# To switch to OpenAI: EMBEDDING_MODEL=text-embedding-3-large, EMBEDDING_DIMENSION=3072
EMBEDDING_MODEL=models/gemini-embedding-001
EMBEDDING_DIMENSION=3072

# ── Agent ──
MAX_RETRIES=3
MAX_CONTEXT_FILES=10
